# Plaid configuration
PLAID_CLIENT_ID=
PLAID_SECRET_SANDBOX=
PLAID_SECRET_PRODUCTION=
PLAID_ENV=production

# Plaid Production Access Tokens
PLAID_ACCESS_TOKEN_DISCOVER=
PLAID_ACCESS_TOKEN_CAPITALONE=
PLAID_ACCESS_TOKEN_VENMO=

# Anthropic API Key
ANTHROPIC_API_KEY=

# Voyage AI — embeddings for semantic memory search (https://voyageai.com)
VOYAGE_SECRET_KEY=

# Fernet encryption key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Database URL (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Flask/itsdangerous signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# JWT secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Set to false for local HTTP dev (secure cookies require HTTPS)
SECURE_COOKIES=true

# Frontend origin for CORS — must match deployed frontend URL
FRONTEND_URL=https://app.wingingbump.com

# URL where the Plaid link service is reachable
LINK_BASE_URL=https://link.wingingbump.com

# Resend email API (https://resend.com) — leave blank to print emails to console in dev
RESEND_API_KEY=
EMAIL_FROM=noreply@wingingbump.com

# Public app URL for email links (no trailing slash)
APP_URL=https://app.wingingbump.com

# Supabase Storage for avatar uploads
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=

# Account deletion grace period in days (default: 30)
DELETION_GRACE_DAYS=30
